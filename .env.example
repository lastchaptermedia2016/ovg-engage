# AI API Keys for Chat & TTS
# Get Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get Grok/XAI API key from: https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# Get ElevenLabs API key from: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Real-Time Booking System Integration (optional)
# Configure to connect to your custom/internal booking system
# BOOKING_API_URL=https://your-booking-system.com/api
# BOOKING_API_KEY=your_booking_api_key
# BOOKING_API_PROVIDER=custom

# Notification API Keys (WhatsApp/SMS/Email)
# Get Twilio credentials from: https://console.twilio.com/
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Get SendGrid API key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=bookings@yourdomain.com

# Supabase Configuration (optional - for analytics & data persistence)
# Get from your Supabase project settings: https://app.supabase.com/
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
